# ── Built .so files in project root ──────────────────────────────────────────
# These are compiled locally and differ per device/platform.
# Distribution binaries go in prebuilt/ instead.
/*.so
/*.cpython-*.so

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/

# ── Rust ─────────────────────────────────────────────────────────────────────
Rust/target/

# ── Test / tooling cache ──────────────────────────────────────────────────────
.pytest_cache/
.hypothesis/

# ── Editors / OS ─────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
otr-env/

# ── Explicitly keep prebuilt/ binaries ───────────────────────────────────────
!prebuilt/*.so
